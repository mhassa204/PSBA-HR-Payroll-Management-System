generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id                      Int                      @id @default(autoincrement())
  employee_id             String?                  @unique
  full_name               String
  father_husband_name     String?
  relationship_type       String?
  mother_name             String?
  cnic                    String?                  @unique
  cnic_issue_date         DateTime?
  cnic_expire_date        DateTime?
  date_of_birth           DateTime?
  gender                  String?
  marital_status          String?
  nationality             String?
  religion                String?
  blood_group             String?
  domicile_district       String?
  mobile_number           String?
  whatsapp_number         String?
  email                   String?                  @unique
  present_address         String?
  permanent_address       String?
  same_address            Boolean                  @default(false)
  // Legacy location fields (deprecated)
  district                String?
  city                    String?
  // New normalized references
  district_id             Int?
  city_id                 Int?
  has_disability          Boolean                  @default(false)
  disability_type         String?
  disability_description  String?
  profile_picture         String?
  missing_note            String?
  status                  String?                  @default("Active")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  is_deleted              Boolean                  @default(false)
  deviceUserId            String?                  @unique
  educationQualifications EducationQualification[]
  documents               EmployeeDocument[]
  employmentRecords       Employment[]
  pastExperiences         PastExperience[]
  user                    User?
  rosterEntries           DutyRosterEntry[]
  // New: leaves for this employee
  leaves                  Leave[]
  // Back-relation: per-bank leave allocations
  leaveBankAllocations    LeaveBankAllocation[]
  // Relations to master data
  districtRef             District?                @relation(fields: [district_id], references: [id])
  cityRef                 City?                    @relation(fields: [city_id], references: [id])
  // Travel back-relations
  travelRequests          TravelRequest[]
  travelClaims            TravelClaim[]
  // New back-relations for travel request attendees and status actions
  travelRequestAttendees  TravelRequestEmployee[]
  travelRequestStatusActions TravelRequestStatusEntry[]
  // Add missing back relation for travel claim status entries
  travelClaimStatusEntries TravelClaimStatusEntry[]
  // New: back relation for departments headed by this employee
  headedDepartments       Department[]            @relation("DepartmentHead")
}

model Department {
  id                Int           @id @default(autoincrement())
  name              String
  code              String?
  description       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  is_deleted        Boolean       @default(false)
  designations      Designation[]
  employmentRecords Employment[]
  // New: optional Head of Department
  head_employee_id  Int?
  head              Employee?     @relation("DepartmentHead", fields: [head_employee_id], references: [id])
  // Back-relation: users optionally linked to this department
  users             User[]
  // Back-relation: travel claims submitted by this department account or HQ-origin
  createdClaims     TravelClaim[]

  @@index([head_employee_id])
}

model Designation {
  id                Int          @id @default(autoincrement())
  title             String
  department_id     Int?
  level             Int?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  is_deleted        Boolean      @default(false)
  department        Department?  @relation(fields: [department_id], references: [id])
  employmentRecords Employment[]

  @@unique([title, department_id], name: "title_department_id")
}

// New master data: Districts and Cities
model District {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  is_active   Boolean @default(true)
  is_deleted  Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cities      City[]
  employees   Employee[]
  locations   Location[]
}

model City {
  id          Int      @id @default(autoincrement())
  name        String
  district_id Int
  is_active   Boolean  @default(true)
  is_deleted  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  district    District @relation(fields: [district_id], references: [id])
  employees   Employee[]
  locations   Location[]

  @@unique([name, district_id], name: "city_name_district_unique")
}

// New master data: Education Levels
model EducationLevel {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  order       Int?
  is_active   Boolean  @default(true)
  is_deleted  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  qualifications EducationQualification[]
}

model RoleTag {
  id                Int          @id @default(autoincrement())
  name              String       @unique
  description       String?
  category          String?
  is_active         Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  is_deleted        Boolean      @default(false)
  employmentRecords Employment[]
}

model ScaleGrade {
  id                Int          @id @default(autoincrement())
  name              String       @unique
  description       String?
  level             Int?
  category          String?
  is_active         Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  is_deleted        Boolean      @default(false)
  employmentRecords Employment[]
  travelRate       TravelRate?
}

// Define per-scale-grade travel rates
model TravelRate {
  id             Int         @id @default(autoincrement())
  scale_grade_id Int         @unique
  rate_per_km    Float       @default(0)
  per_diem_rate  Float       @default(0)
  is_active      Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  scale_grade    ScaleGrade  @relation(fields: [scale_grade_id], references: [id])
}

model PastExperience {
  id           Int      @id @default(autoincrement())
  employee_id  Int
  company_name String
  position     String?
  start_date   String
  end_date     String
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  is_deleted   Boolean  @default(false)
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
}

model EducationQualification {
  id                 Int      @id @default(autoincrement())
  employee_id        Int
  // Legacy level string (deprecated)
  education_level    String
  // New normalized level reference
  education_level_id Int?
  institution_name   String
  year_of_completion String
  marks_gpa          String?
  // New: start date for the education record
  start_date         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  is_deleted         Boolean  @default(false)
  employee           Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  level              EducationLevel? @relation(fields: [education_level_id], references: [id])
}

model EmployeeDocument {
  id            Int      @id @default(autoincrement())
  employee_id   Int
  file_path     String
  file_type     String
  document_name String?
  file_size     Int?
  mime_type     String?
  associated_id Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  is_deleted    Boolean  @default(false)
  employee      Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([associated_id])
}

model Employment {
  id                   Int                  @id @default(autoincrement())
  employee_id          Int
  organization         String
  department_id        Int?
  designation_id       Int?
  employment_type      String               @default("Regular")
  effective_from       DateTime?
  effective_till       DateTime?
  reporting_officer_id String?
  office_location      String?
  remarks              String?
  employment_status    String               @default("active")
  is_current           Boolean              @default(false)
  filer_status         String               @default("non_filer")
  filer_active_status  String?
  is_on_probation      Boolean              @default(false)
  probation_end_date   DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  is_deleted           Boolean              @default(false)
  role_tag_id          Int?
  scale_grade_id       Int?
  department           Department?          @relation(fields: [department_id], references: [id])
  designation          Designation?         @relation(fields: [designation_id], references: [id])
  employee             Employee             @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  role_tag             RoleTag?             @relation(fields: [role_tag_id], references: [id])
  scale_grade          ScaleGrade?          @relation(fields: [scale_grade_id], references: [id])
  contract             EmploymentContract?
  documents            EmploymentDocument[]
  // Changed: reference main Location instead of EmploymentLocation
  location_id          Int?
  location             Location?            @relation(fields: [location_id], references: [id])
  salary               EmploymentSalary?

  @@index([location_id])
}

model EmploymentSalary {
  id                    Int        @id @default(autoincrement())
  employment_id         Int        @unique
  basic_salary          Float      @default(0)
  gross_salary          Float?
  medical_allowance     Float      @default(0)
  house_rent            Float      @default(0)
  conveyance_allowance  Float      @default(0)
  other_allowances      Float      @default(0)
  daily_wage_rate       Float?
  bank_account_primary  String?
  bank_name_primary     String?
  bank_branch_code      String?
  payment_mode          String     @default("Bank Transfer")
  salary_effective_from DateTime?
  salary_effective_till DateTime?
  payroll_status        String     @default("Active")
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  is_deleted            Boolean    @default(false)
  employment            Employment @relation(fields: [employment_id], references: [id], onDelete: Cascade)
}

model EmploymentContract {
  id                  Int        @id @default(autoincrement())
  employment_id       Int        @unique
  contract_type       String?
  contract_number     String?
  start_date          DateTime?
  end_date            DateTime?
  renewal_count       Int        @default(0)
  probation_start     DateTime?
  probation_end       DateTime?
  confirmation_status String?
  confirmation_date   DateTime?
  is_renewed          Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @default(now())
  is_deleted          Boolean    @default(false)
  employment          Employment @relation(fields: [employment_id], references: [id], onDelete: Cascade)
}

model EmploymentDocument {
  id            Int        @id @default(autoincrement())
  employment_id Int
  file_path     String
  file_type     String
  document_name String?
  file_size     Int?
  mime_type     String?
  associated_id Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now())
  is_deleted    Boolean    @default(false)
  employment    Employment @relation(fields: [employment_id], references: [id], onDelete: Cascade)

  @@index([associated_id])
}

model Role {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  type            String   @default("custom")
  is_deleted      Boolean  @default(false)
  enabled         Boolean  @default(true)
  fields          String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           User[]
  rolePermissions RolePermission[]
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  password     String
  role_id      Int
  employee_id  Int?      @unique
  // Optional: link user to a department
  department_id Int?
  // Optional: link user to a location (e.g., bazaar/head office)
  location_id   Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  is_deleted   Boolean   @default(false)
  role         Role      @relation(fields: [role_id], references: [id])
  employee     Employee? @relation(fields: [employee_id], references: [id])
  department    Department? @relation(fields: [department_id], references: [id])
  // Optional reference to a Location for location-based users
  location      Location?  @relation(name: "UserLocation", fields: [location_id], references: [id])
  // back relation for settings updates
  updatedSettings SystemSetting[] @relation("UserUpdatedSettings")
  // back relation for managed locations
  managedLocations Location[] @relation(name: "UserManagedLocations")
  // new: rosters created by this user
  createdRosters DutyRoster[]
  // Back-relation: leave banks created by this user
  createdLeaveBanks LeaveBank[]
  // Back-relation: accounts tranches created by this user
  createdTranches TravelClaimTranche[]

  @@index([department_id])
  @@index([location_id])
}

model Session {
  sid    String   @id @db.VarChar(255)
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@map("session")
}

model Permission {
  id              Int               @id @default(autoincrement())
  key             String            @unique
  resource        String
  action          String
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  role_id       Int
  permission_id Int
  constraints   Json?

  role        Role       @relation(fields: [role_id], references: [id])
  permission  Permission @relation(fields: [permission_id], references: [id])

  @@id([role_id, permission_id])
}

model SystemSetting {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  category   String
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  updatedBy  Int?
  updatedByUser User? @relation(name: "UserUpdatedSettings", fields: [updatedBy], references: [id])

  @@index([category])
}

// New: Master Locations (Head Office and Bazaars)
model Location {
  id              Int       @id @default(autoincrement())
  name            String
  type            String    @default("BAZAAR") // BAZAAR | HEAD_OFFICE
  district_id     Int?
  city_id         Int?
  district        District? @relation(fields: [district_id], references: [id])
  city            City?     @relation(fields: [city_id], references: [id])
  full_address    String?
  // Operational hours (HH:mm)
  opening_time    String?
  closing_time    String?
  is_active       Boolean   @default(true)
  manager_user_id Int?
  manager         User?     @relation(name: "UserManagedLocations", fields: [manager_user_id], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  is_deleted      Boolean   @default(false)
  // new: rosters assigned to this location
  rosters         DutyRoster[]
  // back relation: devices installed at this location
  devices         Device[]
  // back relation: employments assigned to this location
  employments     Employment[]
  // back relation: users optionally linked to this location (distinct from manager)
  users           User[]     @relation(name: "UserLocation")

  @@index([district_id])
  @@index([city_id])
}

// New: Duty Roster master
model DutyRoster {
  id                 Int               @id @default(autoincrement())
  title              String?
  bazaar_id          Int?
  location           Location?         @relation(fields: [bazaar_id], references: [id])
  valid_from         DateTime
  valid_to           DateTime
  created_by_user_id Int
  createdBy          User              @relation(fields: [created_by_user_id], references: [id])
  entries            DutyRosterEntry[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  is_deleted         Boolean           @default(false)
  // New: approval status with default pending
  status             DutyRosterStatus  @default(PENDING)

  @@index([bazaar_id])
  @@index([created_by_user_id])
}

// New: Duty Roster entries per employee
model DutyRosterEntry {
  id               Int        @id @default(autoincrement())
  roster_id        Int
  employee_id      Int
  day_schedules    Json
  remarks          String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  roster           DutyRoster @relation(fields: [roster_id], references: [id])
  employee         Employee   @relation(fields: [employee_id], references: [id])

  @@index([roster_id])
  @@index([employee_id])
}

// New: enum for Duty Roster approval status
enum DutyRosterStatus {
  PENDING
  APPROVED
  REJECTED
}

model Device {
  id           Int       @id @default(autoincrement())
  ip_address   String
  port_number  Int
  location_id  Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  is_deleted   Boolean   @default(false)
  location     Location? @relation(fields: [location_id], references: [id])
  // back relation: attendance records captured via this device
  attendances  Attendance[]

  @@unique([ip_address, port_number], name: "ip_port_unique")
  @@index([location_id])
}

model Attendance {
  id              Int       @id @default(autoincrement())
  deviceUserId    String
  timestamp       DateTime
  type            String    // IN | OUT
  device_ip       String
  device_port     Int
  attendanceDate  DateTime  // normalized day (UTC midnight)
  device_id       Int?
  device          Device?   @relation(fields: [device_id], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([deviceUserId])
  @@index([attendanceDate])
  @@unique([deviceUserId, device_ip, device_port, type, attendanceDate], name: "unique_daily_type_per_device_user")
}

// New: Leave module
model Leave {
  id           Int          @id @default(autoincrement())
  employee_id  Int
  date         DateTime
  type         String
  status       LeaveStatus  @default(PENDING)
  remarks      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @default(now())
  is_deleted   Boolean      @default(false)

  employee     Employee     @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([employee_id, date])
}

// New: enum for Leave status
enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// New: Leave Types for configuring bankable leave categories
model LeaveType {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  code        String?
  is_active   Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @default(now())
  is_deleted  Boolean              @default(false)
  bankDefaults LeaveBankDefault[]
  allocations  LeaveBankAllocation[]
}

// New: Leave Bank period definition (e.g., fiscal year)
model LeaveBank {
  id               Int                    @id @default(autoincrement())
  title            String?
  period_start     DateTime
  period_end       DateTime
  createdByUserId  Int?
  createdBy        User?                  @relation(fields: [createdByUserId], references: [id])
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @default(now())
  is_deleted       Boolean                @default(false)
  defaults         LeaveBankDefault[]
  allocations      LeaveBankAllocation[]
}

// New: Default days per leave type for a leave bank
model LeaveBankDefault {
  id             Int        @id @default(autoincrement())
  leave_bank_id  Int
  leave_type_id  Int
  days           Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @default(now())
  bank           LeaveBank  @relation(fields: [leave_bank_id], references: [id], onDelete: Cascade)
  leaveType      LeaveType  @relation(fields: [leave_type_id], references: [id])

  @@unique([leave_bank_id, leave_type_id], name: "leave_bank_type_unique")
}

// New: Per-employee allocation for a leave bank and type
model LeaveBankAllocation {
  id             Int        @id @default(autoincrement())
  leave_bank_id  Int
  employee_id    Int
  leave_type_id  Int
  days           Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @default(now())
  bank           LeaveBank  @relation(fields: [leave_bank_id], references: [id], onDelete: Cascade)
  employee       Employee   @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  leaveType      LeaveType  @relation(fields: [leave_type_id], references: [id])

  @@unique([leave_bank_id, employee_id, leave_type_id], name: "leave_bank_employee_type_unique")
  @@index([employee_id])
  @@index([leave_type_id])
}

// ===== Travel Module =====

enum TravelClaimStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL // legacy (treated same as APPROVED after first stage)
  VERIFIED         // after HR approval (still used)
  APPROVED         // now specifically means first-stage (OPS/DG) approved
  PROCESSED        // final after Accounts approval
  REJECTED         // legacy generic
  REJECTED_OPS
  REJECTED_DG
  REJECTED_HR
  REJECTED_ACCOUNTS
  PARTIALLY_SETTLED
  SETTLED
}

enum TravelRequestStatus {
  CREATED
  APPROVED
  REJECTED
  CANCELLED
}

enum TravelClaimDocCategory {
  FUEL
  TOLL
  PICTURE
  REPORT
  OTHER
}

model TravelRequest {
  id                   Int                        @id @default(autoincrement())
  applicant_id         Int
  submission_date      DateTime                   @default(now())
  departure_date       DateTime
  departure_time       String?
  expected_return_date DateTime
  purpose              String?
  destination          String?
  total_days           Int?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  is_deleted           Boolean                    @default(false)
  status               TravelRequestStatus       @default(CREATED)

  applicant            Employee                   @relation(fields: [applicant_id], references: [id])
  attendees            TravelRequestEmployee[]
  statusEntries        TravelRequestStatusEntry[]

  // Keep relation for claims if used elsewhere
  claims               TravelClaim[]

  @@index([applicant_id])
}

// Join model for travel request attendees
model TravelRequestEmployee {
  id          Int           @id @default(autoincrement())
  request_id  Int
  employee_id Int
  createdAt   DateTime      @default(now())

  request     TravelRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
  employee    Employee      @relation(fields: [employee_id], references: [id])

  @@unique([request_id, employee_id], name: "request_attendee_unique")
  @@index([employee_id])
}

// Status history for travel requests (includes recommender actions)
model TravelRequestStatusEntry {
  id                 Int            @id @default(autoincrement())
  request_id         Int
  action             String
  remarks            String?
  actor_employee_id  Int?
  createdAt          DateTime       @default(now())

  request            TravelRequest  @relation(fields: [request_id], references: [id], onDelete: Cascade)
  actor              Employee?      @relation(fields: [actor_employee_id], references: [id])

  @@index([request_id])
  @@index([actor_employee_id])
}

model TravelClaim {
  id                 Int               @id @default(autoincrement())
  employee_id        Int
  travel_request_id  Int?
  claim_date         DateTime          @default(now())
  currency           String?           @default("PKR")
  total_claimed      Float             @default(0)
  total_approved     Float?            @default(0)
  notes              String?
  status             TravelClaimStatus @default(DRAFT)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now())
  is_deleted         Boolean           @default(false)
  employee           Employee          @relation(fields: [employee_id], references: [id])
  request            TravelRequest?    @relation(fields: [travel_request_id], references: [id])
  // New single-row per diem + expense fields
  from_date          DateTime?
  to_date            DateTime?
  overnight_stay     Boolean        @default(false)
  // New fields to persist UI transport selections and totals
  transport_mode     String?        @default("OWN") // OWN | OTHER
  fuel_total         Float?         @default(0)
  fare_total         Float?         @default(0)
  total_distance_km  Float?         @default(0)
  rate_per_km        Float?         @default(0)
  distance_amount    Float?         @default(0) // C = A x B
  toll_tax_total     Float?         @default(0) // D
  travel_total       Float?         @default(0) // E = C + D
  per_diem_days      Int?           @default(0)
  per_diem_rate      Float?         @default(0)
  per_diem_amount    Float?         @default(0) // F
  grand_total        Float?         @default(0) // G = E + F
  // New: track which Department submitted the claim (for department-origin/HQ routing)
  created_by_department_id Int?
  createdByDepartment      Department?   @relation(fields: [created_by_department_id], references: [id])
  documents          TravelClaimDocument[]
  segments           TravelClaimSegment[]
  statusEntries      TravelClaimStatusEntry[]
  // Back-relation for tranche items
  trancheItems       TravelClaimTrancheItem[]

  @@unique([travel_request_id, employee_id], name: "request_employee_claim_unique")
  @@index([created_by_department_id])
}

// Status history for expense claims (OPS/DG/HR/Accounts)
model TravelClaimStatusEntry {
  id                 Int          @id @default(autoincrement())
  claim_id           Int
  action             String
  remarks            String?
  actor_employee_id  Int?
  createdAt          DateTime     @default(now())

  claim              TravelClaim  @relation(fields: [claim_id], references: [id], onDelete: Cascade)
  actor              Employee?    @relation(fields: [actor_employee_id], references: [id])

  @@index([claim_id])
  @@index([actor_employee_id])
}

// Segment entries per claim leg
model TravelClaimSegment {
  id             Int          @id @default(autoincrement())
  claim_id       Int
  departure_from String
  departure_to   String
  // Dates and times
  depart_date    DateTime?
  depart_time    String?
  arrive_date    DateTime?
  arrive_time    String?
  mode           String?
  distance_km    Float?       @default(0)
  createdAt      DateTime     @default(now())

  claim          TravelClaim  @relation(fields: [claim_id], references: [id], onDelete: Cascade)

  @@index([claim_id])
}

// Supporting documents for a claim
model TravelClaimDocument {
  id          Int                     @id @default(autoincrement())
  claim_id    Int
  category    TravelClaimDocCategory
  file_path   String
  mime_type   String?
  file_size   Int?
  createdAt   DateTime                @default(now())

  claim       TravelClaim             @relation(fields: [claim_id], references: [id], onDelete: Cascade)

  @@index([claim_id])
  @@index([category])
}

// Accounts processing tranches to group verified claims
model TravelClaimTranche {
  id                 Int                      @id @default(autoincrement())
  code               String?                   @unique
  title              String?
  notes              String?
  createdAt          DateTime                  @default(now())
  created_by_user_id Int?
  createdBy          User?                     @relation(fields: [created_by_user_id], references: [id])
  items              TravelClaimTrancheItem[]
}

model TravelClaimTrancheItem {
  id         Int                @id @default(autoincrement())
  tranche_id Int
  claim_id   Int
  addedAt    DateTime           @default(now())

  tranche    TravelClaimTranche @relation(fields: [tranche_id], references: [id], onDelete: Cascade)
  claim      TravelClaim        @relation(fields: [claim_id], references: [id])

  @@unique([tranche_id, claim_id], name: "tranche_claim_unique")
  @@index([claim_id])
}
