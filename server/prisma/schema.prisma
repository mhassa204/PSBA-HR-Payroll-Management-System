generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id                      Int                      @id @default(autoincrement())
  employee_id             String?                  @unique
  full_name               String
  father_husband_name     String?
  relationship_type       String?
  mother_name             String?
  cnic                    String?                  @unique
  cnic_issue_date         DateTime?
  cnic_expire_date        DateTime?
  date_of_birth           DateTime?
  gender                  String?
  marital_status          String?
  nationality             String?
  religion                String?
  blood_group             String?
  domicile_district       String?
  mobile_number           String?
  whatsapp_number         String?
  email                   String?                  @unique
  present_address         String?
  permanent_address       String?
  same_address            Boolean                  @default(false)
  district                String?
  city                    String?
  has_disability          Boolean                  @default(false)
  disability_type         String?
  disability_description  String?
  profile_picture         String?
  missing_note            String?
  status                  String?                  @default("Active")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  is_deleted              Boolean                  @default(false)
  deviceUserId            String?                  @unique
  educationQualifications EducationQualification[]
  documents               EmployeeDocument[]
  employmentRecords       Employment[]
  pastExperiences         PastExperience[]
  user                    User?
  rosterEntries           DutyRosterEntry[]
}

model Department {
  id                Int           @id @default(autoincrement())
  name              String
  code              String?
  description       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  is_deleted        Boolean       @default(false)
  designations      Designation[]
  employmentRecords Employment[]
}

model Designation {
  id                Int          @id @default(autoincrement())
  title             String
  department_id     Int?
  level             Int?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  is_deleted        Boolean      @default(false)
  department        Department?  @relation(fields: [department_id], references: [id])
  employmentRecords Employment[]

  @@unique([title, department_id], name: "title_department_id")
}

model RoleTag {
  id                Int          @id @default(autoincrement())
  name              String       @unique
  description       String?
  category          String?
  is_active         Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  is_deleted        Boolean      @default(false)
  employmentRecords Employment[]
}

model ScaleGrade {
  id                Int          @id @default(autoincrement())
  name              String       @unique
  description       String?
  level             Int?
  category          String?
  is_active         Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  is_deleted        Boolean      @default(false)
  employmentRecords Employment[]
}

model PastExperience {
  id           Int      @id @default(autoincrement())
  employee_id  Int
  company_name String
  position     String?
  start_date   String
  end_date     String
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  is_deleted   Boolean  @default(false)
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
}

model EducationQualification {
  id                 Int      @id @default(autoincrement())
  employee_id        Int
  education_level    String
  institution_name   String
  year_of_completion String
  marks_gpa          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  is_deleted         Boolean  @default(false)
  employee           Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
}

model EmployeeDocument {
  id            Int      @id @default(autoincrement())
  employee_id   Int
  file_path     String
  file_type     String
  document_name String?
  file_size     Int?
  mime_type     String?
  associated_id Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  is_deleted    Boolean  @default(false)
  employee      Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([associated_id])
}

model Employment {
  id                   Int                  @id @default(autoincrement())
  employee_id          Int
  organization         String
  department_id        Int?
  designation_id       Int?
  employment_type      String               @default("Regular")
  effective_from       DateTime?
  effective_till       DateTime?
  reporting_officer_id String?
  office_location      String?
  remarks              String?
  employment_status    String               @default("active")
  is_current           Boolean              @default(false)
  filer_status         String               @default("non_filer")
  filer_active_status  String?
  is_on_probation      Boolean              @default(false)
  probation_end_date   DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  is_deleted           Boolean              @default(false)
  role_tag_id          Int?
  scale_grade_id       Int?
  department           Department?          @relation(fields: [department_id], references: [id])
  designation          Designation?         @relation(fields: [designation_id], references: [id])
  employee             Employee             @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  role_tag             RoleTag?             @relation(fields: [role_tag_id], references: [id])
  scale_grade          ScaleGrade?          @relation(fields: [scale_grade_id], references: [id])
  contract             EmploymentContract?
  documents            EmploymentDocument[]
  location             EmploymentLocation?
  salary               EmploymentSalary?
}

model EmploymentSalary {
  id                    Int        @id @default(autoincrement())
  employment_id         Int        @unique
  basic_salary          Float      @default(0)
  gross_salary          Float?
  medical_allowance     Float      @default(0)
  house_rent            Float      @default(0)
  conveyance_allowance  Float      @default(0)
  other_allowances      Float      @default(0)
  daily_wage_rate       Float?
  bank_account_primary  String?
  bank_name_primary     String?
  bank_branch_code      String?
  payment_mode          String     @default("Bank Transfer")
  salary_effective_from DateTime?
  salary_effective_till DateTime?
  payroll_status        String     @default("Active")
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  is_deleted            Boolean    @default(false)
  employment            Employment @relation(fields: [employment_id], references: [id], onDelete: Cascade)
}

model EmploymentLocation {
  id            Int        @id @default(autoincrement())
  employment_id Int        @unique
  district      String?
  city          String?
  bazaar_name   String?
  type          String     @default("HEAD_OFFICE")
  full_address  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  is_deleted    Boolean    @default(false)
  employment    Employment @relation(fields: [employment_id], references: [id], onDelete: Cascade)
}

model EmploymentContract {
  id                  Int        @id @default(autoincrement())
  employment_id       Int        @unique
  contract_type       String?
  contract_number     String?
  start_date          DateTime?
  end_date            DateTime?
  renewal_count       Int        @default(0)
  probation_start     DateTime?
  probation_end       DateTime?
  confirmation_status String?
  confirmation_date   DateTime?
  is_renewed          Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  is_deleted          Boolean    @default(false)
  employment          Employment @relation(fields: [employment_id], references: [id], onDelete: Cascade)
}

model EmploymentDocument {
  id            Int        @id @default(autoincrement())
  employment_id Int
  file_path     String
  file_type     String
  document_name String?
  file_size     Int?
  mime_type     String?
  associated_id Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  is_deleted    Boolean    @default(false)
  employment    Employment @relation(fields: [employment_id], references: [id], onDelete: Cascade)

  @@index([associated_id])
}

model Role {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  type            String   @default("custom")
  is_deleted      Boolean  @default(false)
  enabled         Boolean  @default(true)
  fields          String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           User[]
  rolePermissions RolePermission[]
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  password     String
  role_id      Int
  employee_id  Int?      @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  is_deleted   Boolean   @default(false)
  role         Role      @relation(fields: [role_id], references: [id])
  employee     Employee? @relation(fields: [employee_id], references: [id])
  // back relation for settings updates
  updatedSettings SystemSetting[] @relation("UserUpdatedSettings")
  // back relation for managed locations
  managedLocations Location[] @relation(name: "UserManagedLocations")
  // new: rosters created by this user
  createdRosters DutyRoster[]
}

model Session {
  sid    String   @id @db.VarChar(255)
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@map("session")
}

model Permission {
  id              Int               @id @default(autoincrement())
  key             String            @unique
  resource        String
  action          String
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  role_id       Int
  permission_id Int
  constraints   Json?

  role        Role       @relation(fields: [role_id], references: [id])
  permission  Permission @relation(fields: [permission_id], references: [id])

  @@id([role_id, permission_id])
}

model SystemSetting {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  category   String
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  updatedBy  Int?
  updatedByUser User? @relation(name: "UserUpdatedSettings", fields: [updatedBy], references: [id])

  @@index([category])
}

// New: Master Locations (Head Office and Bazaars)
model Location {
  id              Int       @id @default(autoincrement())
  name            String
  type            String    @default("BAZAAR") // BAZAAR | HEAD_OFFICE
  district        String?
  city            String?
  full_address    String?
  // Operational hours (HH:mm)
  opening_time    String?
  closing_time    String?
  is_active       Boolean   @default(true)
  manager_user_id Int?
  manager         User?     @relation(name: "UserManagedLocations", fields: [manager_user_id], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  is_deleted      Boolean   @default(false)
  // new: rosters assigned to this location
  rosters         DutyRoster[]
  // back relation: devices installed at this location
  devices         Device[]
}

// New: Duty Roster master
model DutyRoster {
  id                 Int               @id @default(autoincrement())
  title              String?
  bazaar_id          Int?
  location           Location?         @relation(fields: [bazaar_id], references: [id])
  valid_from         DateTime
  valid_to           DateTime
  created_by_user_id Int
  createdBy          User              @relation(fields: [created_by_user_id], references: [id])
  entries            DutyRosterEntry[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  is_deleted         Boolean           @default(false)
  // New: approval status with default pending
  status             DutyRosterStatus  @default(PENDING)

  @@index([bazaar_id])
  @@index([created_by_user_id])
}

// New: Duty Roster entries per employee
model DutyRosterEntry {
  id               Int        @id @default(autoincrement())
  roster_id        Int
  employee_id      Int
  day_schedules    Json
  remarks          String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  roster           DutyRoster @relation(fields: [roster_id], references: [id])
  employee         Employee   @relation(fields: [employee_id], references: [id])

  @@index([roster_id])
  @@index([employee_id])
}

// New: enum for Duty Roster approval status
enum DutyRosterStatus {
  PENDING
  APPROVED
  REJECTED
}

model Device {
  id           Int       @id @default(autoincrement())
  ip_address   String
  port_number  Int
  location_id  Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  is_deleted   Boolean   @default(false)
  location     Location? @relation(fields: [location_id], references: [id])
  // back relation: attendance records captured via this device
  attendances  Attendance[]

  @@unique([ip_address, port_number], name: "ip_port_unique")
  @@index([location_id])
}

model Attendance {
  id              Int       @id @default(autoincrement())
  deviceUserId    String
  timestamp       DateTime
  type            String    // IN | OUT
  device_ip       String
  device_port     Int
  attendanceDate  DateTime  // normalized day (UTC midnight)
  device_id       Int?
  device          Device?   @relation(fields: [device_id], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([deviceUserId])
  @@index([attendanceDate])
  @@unique([deviceUserId, device_ip, device_port, type, attendanceDate], name: "unique_daily_type_per_device_user")
}
