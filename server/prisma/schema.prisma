generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id                      Int                      @id @default(autoincrement())
  employee_id             String?                  @unique
  full_name               String
  father_husband_name     String?
  relationship_type       String?
  mother_name             String?
  cnic                    String?                  @unique
  cnic_issue_date         DateTime?
  cnic_expire_date        DateTime?
  date_of_birth           DateTime?
  gender                  String?
  marital_status          String?
  nationality             String?
  religion                String?
  blood_group             String?
  domicile_district       String?
  mobile_number           String?
  whatsapp_number         String?
  email                   String?                  @unique
  present_address         String?
  permanent_address       String?
  same_address            Boolean                  @default(false)
  // Legacy location fields (deprecated)
  district                String?
  city                    String?
  // New normalized references
  district_id             Int?
  city_id                 Int?
  has_disability          Boolean                  @default(false)
  disability_type         String?
  disability_description  String?
  profile_picture         String?
  missing_note            String?
  status                  String?                  @default("Active")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  is_deleted              Boolean                  @default(false)
  deviceUserId            String?                  @unique
  educationQualifications EducationQualification[]
  documents               EmployeeDocument[]
  employmentRecords       Employment[]
  pastExperiences         PastExperience[]
  user                    User?
  rosterEntries           DutyRosterEntry[]
  // New: leaves for this employee
  leaves                  Leave[]
  // Back-relation: per-bank leave allocations
  leaveBankAllocations    LeaveBankAllocation[]
  // Relations to master data
  districtRef             District?                @relation(fields: [district_id], references: [id])
  cityRef                 City?                    @relation(fields: [city_id], references: [id])
  // Travel back-relations
  travelRequests          TravelRequest[]
  travelClaims            TravelClaim[]
}

model Department {
  id                Int           @id @default(autoincrement())
  name              String
  code              String?
  description       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  is_deleted        Boolean       @default(false)
  designations      Designation[]
  employmentRecords Employment[]
}

model Designation {
  id                Int          @id @default(autoincrement())
  title             String
  department_id     Int?
  level             Int?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  is_deleted        Boolean      @default(false)
  department        Department?  @relation(fields: [department_id], references: [id])
  employmentRecords Employment[]

  @@unique([title, department_id], name: "title_department_id")
}

// New master data: Districts and Cities
model District {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  is_active   Boolean @default(true)
  is_deleted  Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cities      City[]
  employees   Employee[]
  locations   Location[]
}

model City {
  id          Int      @id @default(autoincrement())
  name        String
  district_id Int
  is_active   Boolean  @default(true)
  is_deleted  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  district    District @relation(fields: [district_id], references: [id])
  employees   Employee[]
  locations   Location[]

  @@unique([name, district_id], name: "city_name_district_unique")
}

// New master data: Education Levels
model EducationLevel {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  order       Int?
  is_active   Boolean  @default(true)
  is_deleted  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  qualifications EducationQualification[]
}

model RoleTag {
  id                Int          @id @default(autoincrement())
  name              String       @unique
  description       String?
  category          String?
  is_active         Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  is_deleted        Boolean      @default(false)
  employmentRecords Employment[]
}

model ScaleGrade {
  id                Int          @id @default(autoincrement())
  name              String       @unique
  description       String?
  level             Int?
  category          String?
  is_active         Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  is_deleted        Boolean      @default(false)
  employmentRecords Employment[]
}

model PastExperience {
  id           Int      @id @default(autoincrement())
  employee_id  Int
  company_name String
  position     String?
  start_date   String
  end_date     String
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  is_deleted   Boolean  @default(false)
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
}

model EducationQualification {
  id                 Int      @id @default(autoincrement())
  employee_id        Int
  // Legacy level string (deprecated)
  education_level    String
  // New normalized level reference
  education_level_id Int?
  institution_name   String
  year_of_completion String
  marks_gpa          String?
  // New: start date for the education record
  start_date         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  is_deleted         Boolean  @default(false)
  employee           Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  level              EducationLevel? @relation(fields: [education_level_id], references: [id])
}

model EmployeeDocument {
  id            Int      @id @default(autoincrement())
  employee_id   Int
  file_path     String
  file_type     String
  document_name String?
  file_size     Int?
  mime_type     String?
  associated_id Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  is_deleted    Boolean  @default(false)
  employee      Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([associated_id])
}

model Employment {
  id                   Int                  @id @default(autoincrement())
  employee_id          Int
  organization         String
  department_id        Int?
  designation_id       Int?
  employment_type      String               @default("Regular")
  effective_from       DateTime?
  effective_till       DateTime?
  reporting_officer_id String?
  office_location      String?
  remarks              String?
  employment_status    String               @default("active")
  is_current           Boolean              @default(false)
  filer_status         String               @default("non_filer")
  filer_active_status  String?
  is_on_probation      Boolean              @default(false)
  probation_end_date   DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  is_deleted           Boolean              @default(false)
  role_tag_id          Int?
  scale_grade_id       Int?
  department           Department?          @relation(fields: [department_id], references: [id])
  designation          Designation?         @relation(fields: [designation_id], references: [id])
  employee             Employee             @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  role_tag             RoleTag?             @relation(fields: [role_tag_id], references: [id])
  scale_grade          ScaleGrade?          @relation(fields: [scale_grade_id], references: [id])
  contract             EmploymentContract?
  documents            EmploymentDocument[]
  // Changed: reference main Location instead of EmploymentLocation
  location_id          Int?
  location             Location?            @relation(fields: [location_id], references: [id])
  salary               EmploymentSalary?

  @@index([location_id])
}

model EmploymentSalary {
  id                    Int        @id @default(autoincrement())
  employment_id         Int        @unique
  basic_salary          Float      @default(0)
  gross_salary          Float?
  medical_allowance     Float      @default(0)
  house_rent            Float      @default(0)
  conveyance_allowance  Float      @default(0)
  other_allowances      Float      @default(0)
  daily_wage_rate       Float?
  bank_account_primary  String?
  bank_name_primary     String?
  bank_branch_code      String?
  payment_mode          String     @default("Bank Transfer")
  salary_effective_from DateTime?
  salary_effective_till DateTime?
  payroll_status        String     @default("Active")
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  is_deleted            Boolean    @default(false)
  employment            Employment @relation(fields: [employment_id], references: [id], onDelete: Cascade)
}

model EmploymentContract {
  id                  Int        @id @default(autoincrement())
  employment_id       Int        @unique
  contract_type       String?
  contract_number     String?
  start_date          DateTime?
  end_date            DateTime?
  renewal_count       Int        @default(0)
  probation_start     DateTime?
  probation_end       DateTime?
  confirmation_status String?
  confirmation_date   DateTime?
  is_renewed          Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  is_deleted          Boolean    @default(false)
  employment          Employment @relation(fields: [employment_id], references: [id], onDelete: Cascade)
}

model EmploymentDocument {
  id            Int        @id @default(autoincrement())
  employment_id Int
  file_path     String
  file_type     String
  document_name String?
  file_size     Int?
  mime_type     String?
  associated_id Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  is_deleted    Boolean    @default(false)
  employment    Employment @relation(fields: [employment_id], references: [id], onDelete: Cascade)

  @@index([associated_id])
}

model Role {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  type            String   @default("custom")
  is_deleted      Boolean  @default(false)
  enabled         Boolean  @default(true)
  fields          String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           User[]
  rolePermissions RolePermission[]
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  password     String
  role_id      Int
  employee_id  Int?      @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  is_deleted   Boolean   @default(false)
  role         Role      @relation(fields: [role_id], references: [id])
  employee     Employee? @relation(fields: [employee_id], references: [id])
  // back relation for settings updates
  updatedSettings SystemSetting[] @relation("UserUpdatedSettings")
  // back relation for managed locations
  managedLocations Location[] @relation(name: "UserManagedLocations")
  // new: rosters created by this user
  createdRosters DutyRoster[]
  // Back-relation: leave banks created by this user
  createdLeaveBanks LeaveBank[]
  approvals         Approval[] @relation("UserApprovals")
}

model Session {
  sid    String   @id @db.VarChar(255)
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@map("session")
}

model Permission {
  id              Int               @id @default(autoincrement())
  key             String            @unique
  resource        String
  action          String
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  role_id       Int
  permission_id Int
  constraints   Json?

  role        Role       @relation(fields: [role_id], references: [id])
  permission  Permission @relation(fields: [permission_id], references: [id])

  @@id([role_id, permission_id])
}

model SystemSetting {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  category   String
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  updatedBy  Int?
  updatedByUser User? @relation(name: "UserUpdatedSettings", fields: [updatedBy], references: [id])

  @@index([category])
}

// New: Master Locations (Head Office and Bazaars)
model Location {
  id              Int       @id @default(autoincrement())
  name            String
  type            String    @default("BAZAAR") // BAZAAR | HEAD_OFFICE
  district_id     Int?
  city_id         Int?
  district        District? @relation(fields: [district_id], references: [id])
  city            City?     @relation(fields: [city_id], references: [id])
  full_address    String?
  // Operational hours (HH:mm)
  opening_time    String?
  closing_time    String?
  is_active       Boolean   @default(true)
  manager_user_id Int?
  manager         User?     @relation(name: "UserManagedLocations", fields: [manager_user_id], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  is_deleted      Boolean   @default(false)
  // new: rosters assigned to this location
  rosters         DutyRoster[]
  // back relation: devices installed at this location
  devices         Device[]
  // back relation: employments assigned to this location
  employments     Employment[]

  @@index([district_id])
  @@index([city_id])
}

// New: Duty Roster master
model DutyRoster {
  id                 Int               @id @default(autoincrement())
  title              String?
  bazaar_id          Int?
  location           Location?         @relation(fields: [bazaar_id], references: [id])
  valid_from         DateTime
  valid_to           DateTime
  created_by_user_id Int
  createdBy          User              @relation(fields: [created_by_user_id], references: [id])
  entries            DutyRosterEntry[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  is_deleted         Boolean           @default(false)
  // New: approval status with default pending
  status             DutyRosterStatus  @default(PENDING)

  @@index([bazaar_id])
  @@index([created_by_user_id])
}

// New: Duty Roster entries per employee
model DutyRosterEntry {
  id               Int        @id @default(autoincrement())
  roster_id        Int
  employee_id      Int
  day_schedules    Json
  remarks          String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  roster           DutyRoster @relation(fields: [roster_id], references: [id])
  employee         Employee   @relation(fields: [employee_id], references: [id])

  @@index([roster_id])
  @@index([employee_id])
}

// New: enum for Duty Roster approval status
enum DutyRosterStatus {
  PENDING
  APPROVED
  REJECTED
}

model Device {
  id           Int       @id @default(autoincrement())
  ip_address   String
  port_number  Int
  location_id  Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  is_deleted   Boolean   @default(false)
  location     Location? @relation(fields: [location_id], references: [id])
  // back relation: attendance records captured via this device
  attendances  Attendance[]

  @@unique([ip_address, port_number], name: "ip_port_unique")
  @@index([location_id])
}

model Attendance {
  id              Int       @id @default(autoincrement())
  deviceUserId    String
  timestamp       DateTime
  type            String    // IN | OUT
  device_ip       String
  device_port     Int
  attendanceDate  DateTime  // normalized day (UTC midnight)
  device_id       Int?
  device          Device?   @relation(fields: [device_id], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([deviceUserId])
  @@index([attendanceDate])
  @@unique([deviceUserId, device_ip, device_port, type, attendanceDate], name: "unique_daily_type_per_device_user")
}

// New: Leave module
model Leave {
  id           Int          @id @default(autoincrement())
  employee_id  Int
  date         DateTime
  type         String
  status       LeaveStatus  @default(PENDING)
  remarks      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  is_deleted   Boolean      @default(false)

  employee     Employee     @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([employee_id, date])
}

// New: enum for Leave status
enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// New: Leave Types for configuring bankable leave categories
model LeaveType {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  code        String?
  is_active   Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  is_deleted  Boolean              @default(false)
  bankDefaults LeaveBankDefault[]
  allocations  LeaveBankAllocation[]
}

// New: Leave Bank period definition (e.g., fiscal year)
model LeaveBank {
  id               Int                    @id @default(autoincrement())
  title            String?
  period_start     DateTime
  period_end       DateTime
  createdByUserId  Int?
  createdBy        User?                  @relation(fields: [createdByUserId], references: [id])
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  is_deleted       Boolean                @default(false)
  defaults         LeaveBankDefault[]
  allocations      LeaveBankAllocation[]
}

// New: Default days per leave type for a leave bank
model LeaveBankDefault {
  id             Int        @id @default(autoincrement())
  leave_bank_id  Int
  leave_type_id  Int
  days           Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  bank           LeaveBank  @relation(fields: [leave_bank_id], references: [id], onDelete: Cascade)
  leaveType      LeaveType  @relation(fields: [leave_type_id], references: [id])

  @@unique([leave_bank_id, leave_type_id], name: "leave_bank_type_unique")
}

// New: Per-employee allocation for a leave bank and type
model LeaveBankAllocation {
  id             Int        @id @default(autoincrement())
  leave_bank_id  Int
  employee_id    Int
  leave_type_id  Int
  days           Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  bank           LeaveBank  @relation(fields: [leave_bank_id], references: [id], onDelete: Cascade)
  employee       Employee   @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  leaveType      LeaveType  @relation(fields: [leave_type_id], references: [id])

  @@unique([leave_bank_id, employee_id, leave_type_id], name: "leave_bank_employee_type_unique")
  @@index([employee_id])
  @@index([leave_type_id])
}

// ===== Travel Module & Generic Workflow Engine =====

enum TravelRequestStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  RETURNED
  CANCELLED
}

enum TravelClaimStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  VERIFIED
  APPROVED
  REJECTED
  PARTIALLY_SETTLED
  SETTLED
}

enum WorkflowInstanceStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum WorkflowStepStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum ApprovalDecision {
  APPROVE
  REJECT
  RETURN
}

enum ApprovalMode {
  ALL
  ANY
  QUORUM
}

model TravelRequest {
  id              Int                  @id @default(autoincrement())
  applicant_id    Int
  purpose         String?
  destination     String?
  departure_date  DateTime?
  departure_time  String?
  return_date     DateTime?
  return_time     String?
  total_days      Int?
  transport_mode  String?
  estimated_cost  Float?               @default(0)
  cost_center     String?
  status          TravelRequestStatus  @default(DRAFT)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  is_deleted      Boolean              @default(false)
  applicant       Employee             @relation(fields: [applicant_id], references: [id])
  claims          TravelClaim[]
  documents       TravelRequestDocument[]
  
  @@index([applicant_id])
}

model TravelRequestDocument {
  id            Int            @id @default(autoincrement())
  request_id    Int
  file_path     String
  document_name String?
  mime_type     String?
  file_size     Int?
  createdAt     DateTime       @default(now())
  request       TravelRequest  @relation(fields: [request_id], references: [id], onDelete: Cascade)

  @@index([request_id])
}

model TravelClaim {
  id                 Int               @id @default(autoincrement())
  employee_id        Int
  travel_request_id  Int?
  claim_date         DateTime          @default(now())
  currency           String?           @default("PKR")
  total_claimed      Float             @default(0)
  total_approved     Float?            @default(0)
  notes              String?
  status             TravelClaimStatus @default(DRAFT)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  is_deleted         Boolean           @default(false)
  employee           Employee          @relation(fields: [employee_id], references: [id])
  request            TravelRequest?    @relation(fields: [travel_request_id], references: [id])
  items              TravelClaimItem[]

  @@index([employee_id])
  @@index([travel_request_id])
}

model TravelClaimItem {
  id            Int          @id @default(autoincrement())
  claim_id      Int
  date          DateTime
  category      String
  description   String?
  amount        Float        @default(0)
  receipt_path  String?
  mime_type     String?
  file_size     Int?
  createdAt     DateTime     @default(now())
  claim         TravelClaim  @relation(fields: [claim_id], references: [id], onDelete: Cascade)
  // New: multiple receipts per item
  receipts      TravelClaimReceipt[]

  @@index([claim_id])
}

model TravelClaimReceipt {
  id            Int              @id @default(autoincrement())
  item_id       Int
  file_path     String
  document_name String?
  mime_type     String?
  file_size     Int?
  createdAt     DateTime         @default(now())
  item          TravelClaimItem  @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@index([item_id])
}

model WorkflowDefinition {
  id          Int       @id @default(autoincrement())
  key         String    @unique // e.g., "travel.request", "travel.claim"
  name        String
  is_active   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  steps       WorkflowStepDefinition[]
}

model WorkflowStepDefinition {
  id                     Int                 @id @default(autoincrement())
  workflow_definition_id Int
  order                  Int
  name                   String
  approval_mode          ApprovalMode        @default(ALL)
  required_count         Int?                // used for QUORUM
  dynamic_assignees      Json                // [{type:'REPORTING_OFFICER'},{type:'PERMISSION',value:'travel.approval'}]
  conditions             Json?               // optional conditions like thresholds
  definition             WorkflowDefinition  @relation(fields: [workflow_definition_id], references: [id], onDelete: Cascade)
  step_instances     WorkflowStepInstance[]

  @@index([workflow_definition_id])
  @@unique([workflow_definition_id, order], name: "wfdef_order_unique")
}

model WorkflowInstance {
  id                 Int                     @id @default(autoincrement())
  target_type        String                  // 'TravelRequest' | 'TravelClaim' | ...
  target_id          Int
  status             WorkflowInstanceStatus  @default(PENDING)
  current_step_order Int?                    // null when finished
  createdAt          DateTime                @default(now())
  updatedAt          DateTime               @updatedAt
  step_instances     WorkflowStepInstance[]

  @@index([target_type, target_id])
}

model WorkflowStepInstance {
  id                 Int                @id @default(autoincrement())
  instance_id        Int
  step_def_id        Int
  order              Int
  status             WorkflowStepStatus @default(PENDING)
  approval_mode      ApprovalMode       @default(ALL)
  required_count     Int?
  approved_count     Int?               @default(0)
  assignees          Json               // resolved user ids at runtime
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  instance           WorkflowInstance   @relation(fields: [instance_id], references: [id], onDelete: Cascade)
  step_definition    WorkflowStepDefinition @relation(fields: [step_def_id], references: [id])
  approvals          Approval[]

  @@index([instance_id])
  @@index([step_def_id])
}

model Approval {
  id               Int               @id @default(autoincrement())
  step_instance_id Int
  approver_user_id Int
  decision         ApprovalDecision
  comment          String?
  decided_at       DateTime          @default(now())
  step_instance    WorkflowStepInstance @relation(fields: [step_instance_id], references: [id], onDelete: Cascade)
  approver         User              @relation(name: "UserApprovals", fields: [approver_user_id], references: [id])

  @@index([step_instance_id])
  @@index([approver_user_id])
}
